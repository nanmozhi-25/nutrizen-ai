# MongoDB Atlas connection string (get this from Atlas dashboard)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/nutrizen?retryWrites=true&w=majority

# Any long random string — used to sign login tokens
JWT_SECRET=replace_this_with_a_long_random_string

# Port the backend server runs on
PORT=5000

# Frontend URL (for CORS) — update after you deploy the frontend
CLIENT_URL=http://localhost:3000
